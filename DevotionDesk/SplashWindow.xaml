<Window x:Class="DevotionDesk.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:svgc="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        mc:Ignorable="d"
        Title="DevotionDesk"
        Width="520"
        Height="320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="IntroStoryboard">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentPanel"
                                           Storyboard.TargetProperty="Opacity">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.7" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:2.3" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Border x:Name="ContentPanel"
                Opacity="0"
                Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="26"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <svgc:SvgViewbox Width="88"
                                     Height="88"
                                     Margin="0,0,0,14"
                                     IsHitTestVisible="False"
                                     Source="pack://application:,,,/Assets/DevotionDeskLogo.svg" />

                    <TextBlock Text="DevotionDesk"
                               FontFamily="{StaticResource FontUIBold}"
                               FontWeight="SemiBold"
                               FontSize="30"
                               Foreground="{DynamicResource TextBold}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Preparing your desk..."
                               Margin="0,10,0,0"
                               FontFamily="{StaticResource FontSubText}"
                               FontSize="14"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="© 2026 Justin Conferido"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
