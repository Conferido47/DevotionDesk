<Application x:Class="DevotionDesk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DevotionDesk">

    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Default theme; App.xaml.cs swaps this at startup -->
                <ResourceDictionary Source="Themes/Theme.Light.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <!-- ===================== -->
        <!-- 🎨 COLOR SYSTEM -->
        <!-- ===================== -->

        <!-- Dusty pastel accents -->
        <SolidColorBrush x:Key="AccEmperor"   Color="#FFC9B6E6"/>
        <SolidColorBrush x:Key="AccEarth"     Color="#FFD9BFB3"/>
        <SolidColorBrush x:Key="AccGrapevine" Color="#FFE3B7C7"/>
        <SolidColorBrush x:Key="AccDenim"     Color="#FFB8CBE0"/>
        <SolidColorBrush x:Key="AccCampfire"  Color="#FFFFD3B8"/>
        <SolidColorBrush x:Key="AccTreeFrog"  Color="#FFCBE7B8"/>
        <SolidColorBrush x:Key="AccMing"      Color="#FFC4E3E8"/>
        <SolidColorBrush x:Key="AccWarm"      Color="#FFFFE7B3"/>
        <SolidColorBrush x:Key="AccCool"      Color="#FFC9DBC9"/>

        <!-- Theme controls AccentBrush / AccentPrimary -->

        <!-- ===================== -->
        <!-- 🔤 FONT FAMILIES -->
        <!-- ===================== -->

        <FontFamily x:Key="FontSubText">
            pack://application:,,,/Fonts/#Montserrat
        </FontFamily>

        <FontFamily x:Key="FontUIBold">
            pack://application:,,,/Fonts/#Montserrat
        </FontFamily>


        <!-- ===================== -->
        <!-- 🪟 WINDOW DEFAULT -->
        <!-- ===================== -->

        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource BgApp}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontSubText}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ===================== -->
        <!-- 📝 TEXT -->
        <!-- ===================== -->

        <!-- Default text = Montserrat -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontSubText}"/>
            <Setter Property="FontWeight" Value="Light"/>
        </Style>

        <!-- Subtext / devotional paragraphs -->
        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontSubText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
        </Style>

        <!-- Navigation / PDF / Readers headers -->
        <Style x:Key="NavHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontUIBold}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBold}"/>
        </Style>
        
        <Style x:Key="UiBold" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontUIBold}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBold}"/>
        </Style>


        <!-- ===================== -->
        <!-- 🧱 LUXURY CARDS -->
        <!-- ===================== -->

        <Style x:Key="LuxuryCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <Style x:Key="LuxuryInner" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCardSoft}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- ===================== -->
        <!-- 📚 LISTS -->
        <!-- ===================== -->

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"
                                         Property="Background"
                                         Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd"
                                         Property="Background"
                                         Value="{DynamicResource SelectionFill}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== -->
        <!-- ✏️ INPUT -->
        <!-- ===================== -->

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="{StaticResource FontSubText}"/>
        </Style>

        <!-- ===================== -->
        <!-- 🔘 BUTTONS -->
        <!-- ===================== -->

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgCardSoft}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== -->
        <!-- 🔀 SPLITTER -->
        <!-- ===================== -->

        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- ===================== -->
        <!-- 🧵 SCROLLBARS -->
        <!-- ===================== -->

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <!-- Thin cylinder look with comfortable hit area -->
            <Setter Property="MinWidth" Value="12"/>
            <Setter Property="MinHeight" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Vertical end buttons -->
                            <RepeatButton x:Name="VDecButton"
                                          Grid.Row="0" Grid.Column="1"
                                          Command="ScrollBar.LineUpCommand"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          Height="14" Width="12"
                                          Margin="0,2,0,2"
                                          Opacity="0.25"
                                          IsTabStop="False">
                                <Border Background="{DynamicResource ScrollButtonBg}"
                                        CornerRadius="999"
                                        Width="10" Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                                        <Path Data="M2,6 L5,3 L8,6"
                                              Stroke="{DynamicResource ScrollThumb}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Viewbox>
                                </Border>
                            </RepeatButton>

                            <RepeatButton x:Name="VIncButton"
                                          Grid.Row="2" Grid.Column="1"
                                          Command="ScrollBar.LineDownCommand"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          Height="14" Width="12"
                                          Margin="0,2,0,2"
                                          Opacity="0.25"
                                          IsTabStop="False">
                                <Border Background="{DynamicResource ScrollButtonBg}"
                                        CornerRadius="999"
                                        Width="10" Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                                        <Path Data="M2,4 L5,7 L8,4"
                                              Stroke="{DynamicResource ScrollThumb}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Viewbox>
                                </Border>
                            </RepeatButton>

                            <!-- Horizontal end buttons -->
                            <RepeatButton x:Name="HDecButton"
                                          Grid.Row="1" Grid.Column="0"
                                          Command="ScrollBar.LineLeftCommand"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          Height="12" Width="14"
                                          Margin="2,0,2,0"
                                          Opacity="0.25"
                                          Visibility="Collapsed"
                                          IsTabStop="False">
                                <Border Background="{DynamicResource ScrollButtonBg}"
                                        CornerRadius="999"
                                        Width="10" Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                                        <Path Data="M6,2 L3,5 L6,8"
                                              Stroke="{DynamicResource ScrollThumb}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Viewbox>
                                </Border>
                            </RepeatButton>

                            <RepeatButton x:Name="HIncButton"
                                          Grid.Row="1" Grid.Column="2"
                                          Command="ScrollBar.LineRightCommand"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          Height="12" Width="14"
                                          Margin="2,0,2,0"
                                          Opacity="0.25"
                                          Visibility="Collapsed"
                                          IsTabStop="False">
                                <Border Background="{DynamicResource ScrollButtonBg}"
                                        CornerRadius="999"
                                        Width="10" Height="10"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Viewbox Width="10" Height="10" Stretch="Uniform">
                                        <Path Data="M4,2 L7,5 L4,8"
                                              Stroke="{DynamicResource ScrollThumb}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Viewbox>
                                </Border>
                            </RepeatButton>

                            <!-- Rail + thumb -->
                            <Grid x:Name="TrackHost" Grid.Row="1" Grid.Column="1" Margin="0,2">
                                <Border x:Name="TrackBg"
                                        Background="{DynamicResource ScrollTrackBg}"
                                        CornerRadius="999"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        Width="3"
                                        Margin="0,2"/>

                                <Track x:Name="PART_Track"
                                       Orientation="{TemplateBinding Orientation}"
                                       IsDirectionReversed="True"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton x:Name="PageDecButton"
                                                      Command="ScrollBar.PageUpCommand"
                                                      Background="Transparent"
                                                      Opacity="0.01"
                                                      IsTabStop="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb x:Name="Thumb" Background="{DynamicResource ScrollThumb}" MinHeight="34">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="ThumbBd"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="999"
                                                            Width="5"
                                                            HorizontalAlignment="Center"/>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ScrollBar}}" Value="Horizontal">
                                                            <Setter TargetName="ThumbBd" Property="Width" Value="Auto"/>
                                                            <Setter TargetName="ThumbBd" Property="Height" Value="5"/>
                                                            <Setter TargetName="ThumbBd" Property="VerticalAlignment" Value="Center"/>
                                                            <Setter TargetName="ThumbBd" Property="HorizontalAlignment" Value="Stretch"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton x:Name="PageIncButton"
                                                      Command="ScrollBar.PageDownCommand"
                                                      Background="Transparent"
                                                      Opacity="0.01"
                                                      IsTabStop="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="VDecButton" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="VIncButton" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="HDecButton" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="HIncButton" Property="Visibility" Value="Visible"/>

                                <Setter TargetName="TrackHost" Property="Margin" Value="2,0"/>
                                <Setter TargetName="TrackBg" Property="Width" Value="Auto"/>
                                <Setter TargetName="TrackBg" Property="Height" Value="3"/>
                                <Setter TargetName="TrackBg" Property="VerticalAlignment" Value="Center"/>
                                <Setter TargetName="TrackBg" Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter TargetName="TrackBg" Property="Margin" Value="2,0"/>

                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                                <Setter TargetName="PageDecButton" Property="Command" Value="ScrollBar.PageLeftCommand"/>
                                <Setter TargetName="PageIncButton" Property="Command" Value="ScrollBar.PageRightCommand"/>
                                <Setter TargetName="Thumb" Property="MinHeight" Value="0"/>
                                <Setter TargetName="Thumb" Property="MinWidth" Value="34"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="VDecButton" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="VIncButton" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="HDecButton" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="HIncButton" Property="Opacity" Value="0.7"/>
                            </Trigger>

                            <Trigger SourceName="VDecButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="VDecButton" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger SourceName="VIncButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="VIncButton" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger SourceName="HDecButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="HDecButton" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger SourceName="HIncButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="HIncButton" Property="Opacity" Value="0.9"/>
                            </Trigger>

                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                            <Trigger SourceName="Thumb" Property="IsDragging" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollThumbDrag}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <!-- Only set thickness; don't force scrollbar length -->
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="12"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        </ResourceDictionary>

    </Application.Resources>
</Application>
