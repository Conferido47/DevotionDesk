<Window x:Class="DevotionDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:svgc="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="DevotionDesk"
        Height="720"
        Width="1403"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Window caption icons -->
        <Geometry x:Key="IconMinimize">M 2 6 L 10 6</Geometry>
        <Geometry x:Key="IconMaximize">M 2 2 L 10 2 L 10 10 L 2 10 Z</Geometry>
        <Geometry x:Key="IconClose">M 2 2 L 10 10 M 10 2 L 2 10</Geometry>

        <!-- Window caption buttons -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CaptionHoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CaptionPressedFill}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CloseHoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ClosePressedFill}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LuxuryToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource FontUIBold}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverFill}"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPrimary}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentPrimary}"/>
                                <Setter Property="Foreground" Value="{DynamicResource OnAccent}"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="1"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsPressed" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox (includes ToggleButton so dropdown actually opens) -->
        <Style x:Key="LuxuryComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="{DynamicResource BgCardSoft}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Clickable surface -->
                            <ToggleButton x:Name="ToggleBtn"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10">
                                            <Grid>
                                                <ContentPresenter Margin="4,0,34,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                 <TextBlock Text="▾"
                                                            Foreground="{DynamicResource TextMuted}"
                                                            FontSize="16"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,0,12,0"/>
                                            </Grid>
                                        </Border>
                                         <ControlTemplate.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverFill}"/>
                                             </Trigger>
                                             <Trigger Property="IsEnabled" Value="False">
                                                 <Setter Property="Opacity" Value="0.45"/>
                                             </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=ToggleBtn}"
                                   HorizontalOffset="0"
                                   VerticalOffset="2"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource BgCard}"
                                        BorderBrush="{DynamicResource BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="6"
                                        MinWidth="{Binding ActualWidth, ElementName=ToggleBtn}"
                                        Width="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bible selectors: tile/grid dropdowns (rows + columns) -->
        <Style x:Key="BibleTileComboBox" TargetType="ComboBox" BasedOn="{StaticResource LuxuryComboBox}">
            <Setter Property="FontFamily" Value="{StaticResource FontUIBold}"/>
            <Setter Property="MaxDropDownHeight" Value="420"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BibleTileComboBoxItemBase" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Tile"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderSoft}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource SelectionFill}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BibleBookTileItem" TargetType="ComboBoxItem" BasedOn="{StaticResource BibleTileComboBoxItemBase}">
            <Setter Property="Width" Value="180"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Tile"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderSoft}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="{StaticResource FontUIBold}"
                                           Foreground="{DynamicResource TextMain}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource SelectionFill}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BibleNumberTileItem" TargetType="ComboBoxItem" BasedOn="{StaticResource BibleTileComboBoxItemBase}">
            <Setter Property="Width" Value="54"/>
        </Style>

        <Style x:Key="BibleBookComboBox" TargetType="ComboBox" BasedOn="{StaticResource BibleTileComboBox}">
            <Setter Property="Tag" Value="560"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource BibleBookTileItem}"/>
        </Style>

        <Style x:Key="BibleNumberComboBox" TargetType="ComboBox" BasedOn="{StaticResource BibleTileComboBox}">
            <Setter Property="Tag" Value="320"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource BibleNumberTileItem}"/>
        </Style>

        <!-- Dropdown items -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{DynamicResource SelectionFill}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context menu styling (dark, no white box) -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="MiBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MiBorder" Property="Background" Value="{DynamicResource HoverFill}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider (used for Bible text zoom) -->
        <Style x:Key="LuxurySlider" TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid SnapsToDevicePixels="True">
                            <!-- Clean rail (no filled left/right segments) -->
                            <Border Height="2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource BorderSoft}"
                                    CornerRadius="1"/>
                            <Track x:Name="PART_Track"
                                   Height="14"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource TextMain}"
                                                        BorderBrush="{DynamicResource BorderSoft}"
                                                        BorderThickness="1"
                                                        CornerRadius="999">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="10"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.25"
                                                                          Color="#000000"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger SourceName="Thumb" Property="IsDragging" Value="True">
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid Background="{DynamicResource BgApp}">

        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgCard}"
                BorderBrush="{DynamicResource BorderSoft}"
                BorderThickness="0,0,0,1"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid Height="44"
                  Margin="12,0,8,0"
                  Background="Transparent"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  MouseRightButtonUp="TitleBar_MouseRightButtonUp">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <svgc:SvgViewbox Width="28"
                                     Height="28"
                                     Margin="0,0,10,0"
                                     IsHitTestVisible="False"
                                     Source="pack://application:,,,/Assets/DevotionDeskLogo.svg" />
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontFamily="{StaticResource FontUIBold}"
                               FontSize="14"
                               Foreground="{DynamicResource TextBold}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButton}"
                            ToolTip="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeButton_Click">
                        <Path Data="{StaticResource IconMinimize}"
                              Stroke="{DynamicResource TextMain}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              SnapsToDevicePixels="True"/>
                    </Button>

                    <Button Style="{StaticResource CaptionButton}"
                            ToolTip="Maximize / Restore"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaxRestoreButton_Click">
                        <Path Data="{StaticResource IconMaximize}"
                              Stroke="{DynamicResource TextMain}"
                              StrokeThickness="1.6"
                              StrokeLineJoin="Round"
                              SnapsToDevicePixels="True"/>
                    </Button>

                    <Button Style="{StaticResource CaptionCloseButton}"
                            ToolTip="Close"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_Click">
                        <Path Data="{StaticResource IconClose}"
                              Stroke="{DynamicResource TextMain}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              SnapsToDevicePixels="True"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- App content -->
        <Grid Grid.Row="1" Background="{DynamicResource BgApp}">

        <!-- MAIN COLUMNS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== -->
        <!-- LEFT: PDFs -->
        <!-- ===================== -->
        <Border Grid.Column="0" Style="{StaticResource LuxuryCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                   Text="PDFs"
                   Style="{StaticResource NavHeader}"/>

                <TextBlock Grid.Row="1"
                   Text="Devotionals"
                   Margin="0,2,0,12"
                   Foreground="{DynamicResource TextMuted}"/>

                <!-- LIST + SORT -->
<Border Grid.Row="2" Style="{StaticResource LuxuryInner}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ComboBox x:Name="SortCombo"
                  Margin="0,0,0,10"
                  SelectionChanged="SortCombo_SelectionChanged" Style="{StaticResource LuxuryComboBox}">
            <ComboBoxItem Content="Sort: A → Z" IsSelected="True"/>
            <ComboBoxItem Content="Sort: Z → A"/>
            <ComboBoxItem Content="Sort: Newest first"/>
            <ComboBoxItem Content="Sort: Oldest first"/>
        </ComboBox>

        <ListBox Grid.Row="1"
                  x:Name="PdfListBox"
                  FontFamily="{StaticResource FontUIBold}"
                  FontSize="13"
                  DisplayMemberPath="DisplayName"
                  SelectionChanged="PdfListBox_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="PdfListBoxItem_PreviewMouseRightButtonDown"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <ContextMenu.Resources>
                        <Style TargetType="{x:Type Separator}">
                            <Setter Property="Margin" Value="8,6"/>
                            <Setter Property="Background" Value="{DynamicResource BorderSoft}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Separator}">
                                        <Border Height="1" Background="{TemplateBinding Background}"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ContextMenu.Resources>

                    <MenuItem Header="Rename (display name)" Click="RenamePdf_Click"/>
                    <Separator/>
                    <MenuItem Header="Reset name" Click="ResetPdfName_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </Grid>
</Border>
            </Grid>
        </Border>


        <GridSplitter Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"/>

        <!-- ===================== -->
        <!-- CENTER: READER -->
        <!-- ===================== -->
        <Border Grid.Column="2" Style="{StaticResource LuxuryCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Reader"
                           Style="{StaticResource NavHeader}"/>

                <Border Grid.Row="1" Style="{StaticResource LuxuryInner}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Custom PDF controls (pdf.js) -->
                        <Border x:Name="PdfToolbar"
                                 Grid.Row="0"
                                 Background="{DynamicResource BgCardSoft}"
                                 BorderBrush="{DynamicResource BorderSoft}"
                                 BorderThickness="1"
                                 CornerRadius="12"
                                 Padding="10,8"
                                 Margin="0,0,0,10"
                                 Visibility="Collapsed">
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                     <Button x:Name="PdfPrevButton"
                                             Content="Prev"
                                             Click="PdfPrevButton_Click"
                                             Padding="14,8"
                                             Margin="0,0,8,0"
                                             Background="{DynamicResource BgCardSoft}"
                                             Foreground="{DynamicResource TextMain}"
                                             BorderBrush="{DynamicResource BorderSoft}"
                                             BorderThickness="1"
                                             Cursor="Hand"
                                             FontFamily="{StaticResource FontUIBold}"/>
                                     <Button x:Name="PdfNextButton"
                                             Content="Next"
                                             Click="PdfNextButton_Click"
                                             Padding="14,8"
                                             Margin="0,0,14,0"
                                             Background="{DynamicResource BgCardSoft}"
                                             Foreground="{DynamicResource TextMain}"
                                             BorderBrush="{DynamicResource BorderSoft}"
                                             BorderThickness="1"
                                             Cursor="Hand"
                                             FontFamily="{StaticResource FontUIBold}"/>

                                     <TextBlock Text="Page"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource TextMuted}"
                                                Margin="0,0,8,0"/>

                                    <Border Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource InputBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="6,2"
                                            Margin="0,0,8,0">
                                        <TextBox x:Name="PdfPageTextBox"
                                                 Width="56"
                                                 Padding="6,4"
                                                 VerticalContentAlignment="Center"
                                                 TextAlignment="Center"
                                                 KeyDown="PdfPageTextBox_KeyDown"
                                                 LostFocus="PdfPageTextBox_LostFocus"
                                                 FontFamily="{StaticResource FontUIBold}"/>
                                    </Border>

                                     <TextBlock x:Name="PdfPageCountText"
                                                Text="/ 0"
                                                VerticalAlignment="Center"
                                                Foreground="{DynamicResource TextMuted}"
                                                Margin="0,0,14,0"/>
                                </StackPanel>

                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                     <Button x:Name="PdfZoomOutButton"
                                            Content="-"
                                            Click="PdfZoomOutButton_Click"
                                            Padding="12,8"
                                            Margin="0,0,8,0"
                                            Background="Transparent"
                                             Foreground="{DynamicResource TextMain}"
                                             BorderBrush="{DynamicResource BorderSoft}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            FontFamily="{StaticResource FontUIBold}"/>

                                     <TextBlock x:Name="PdfZoomText"
                                               Text="100%"
                                               VerticalAlignment="Center"
                                                Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,8,0"
                                               FontFamily="{StaticResource FontUIBold}"/>

                                     <Button x:Name="PdfZoomInButton"
                                            Content="+"
                                            Click="PdfZoomInButton_Click"
                                            Padding="12,8"
                                            Margin="0,0,10,0"
                                            Background="Transparent"
                                             Foreground="{DynamicResource TextMain}"
                                             BorderBrush="{DynamicResource BorderSoft}"
                                            BorderThickness="1"
                                            Cursor="Hand"
                                            FontFamily="{StaticResource FontUIBold}"/>

                                     <Button x:Name="PdfFitWidthButton"
                                             Content="Fit width"
                                             Click="PdfFitWidthButton_Click"
                                             Padding="14,8"
                                             Background="{DynamicResource AccentPrimary}"
                                             Foreground="{DynamicResource OnAccent}"
                                             BorderBrush="{DynamicResource AccentPrimary}"
                                             BorderThickness="1"
                                             Cursor="Hand"
                                             FontFamily="{StaticResource FontUIBold}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Viewer surface -->
                        <Grid Grid.Row="1">
                             <TextBlock x:Name="ReaderStatusText"
                                        Text="(Select a PDF on the left)"
                                        Foreground="{DynamicResource TextMuted}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        TextWrapping="Wrap"/>

                            <wv2:WebView2 x:Name="PdfWebView"
                                          Visibility="Collapsed"
                                          NavigationCompleted="PdfWebView_NavigationCompleted"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="3"
                      Width="6"
                      HorizontalAlignment="Stretch"/>

        <!-- ===================== -->
        <!-- RIGHT: BIBLE + NOTES -->
        <!-- ===================== -->
        <Grid Grid.Column="4" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Theme toggle -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,8">
                <Button x:Name="ThemeLightButton"
                        Content="Light"
                        Click="ThemeLightButton_Click"
                        Padding="12,7"
                        Margin="0,0,6,0"
                        FontFamily="{StaticResource FontUIBold}"/>
                <Button x:Name="ThemeDarkButton"
                        Content="Dark"
                        Click="ThemeDarkButton_Click"
                        Padding="12,7"
                        FontFamily="{StaticResource FontUIBold}"/>
            </StackPanel>

            <!-- Bible -->
            <Border Grid.Row="1" Style="{StaticResource LuxuryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="Bible"
                                   Style="{StaticResource NavHeader}"
                                   DockPanel.Dock="Left"/>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <ComboBox x:Name="BibleTranslationCombo"
                                      Width="170"
                                      Margin="0,0,10,0"
                                      SelectionChanged="BibleTranslationCombo_SelectionChanged"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      Style="{StaticResource LuxuryComboBox}"/>

                            <ToggleButton x:Name="BibleCompareToggle"
                                          Content="Compare"
                                          Margin="0,0,10,0"
                                          Style="{StaticResource LuxuryToggleButton}"
                                          Checked="BibleCompareToggle_Checked"
                                          Unchecked="BibleCompareToggle_Unchecked"/>

                            <ComboBox x:Name="BibleCompareTranslationCombo"
                                      Width="170"
                                      Margin="0,0,10,0"
                                      SelectionChanged="BibleCompareTranslationCombo_SelectionChanged"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Id"
                                      Style="{StaticResource LuxuryComboBox}"
                                      Visibility="Collapsed"/>

                            <Button x:Name="BibleDownloadButton"
                                    Content="Download offline"
                                    Click="BibleDownloadButton_Click"
                                    Padding="12,6"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextMain}"
                                    BorderBrush="{DynamicResource BorderSoft}"
                                    BorderThickness="1"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Text="Read scripture instantly with quick book, chapter, verse, or keyword"
                               Margin="0,2,0,12"
                               Foreground="{DynamicResource TextMuted}"/>

                    <Border Grid.Row="2" Style="{StaticResource LuxuryInner}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,12">
                                <Border Width="280"
                                        Margin="0,0,10,0"
                                        Background="{DynamicResource InputBg}"
                                        BorderBrush="{DynamicResource InputBorder}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10,6">
                                     <DockPanel>
                                        <!-- Magnifying glass (stroke) -->
                                        <Path Data="M10,18 A8,8 0 1 1 18,10 A8,8 0 0 1 10,18 M16.5,16.5 L22,22"
                                              Stroke="{DynamicResource TextMuted}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Width="18"
                                              Height="18"
                                              Stretch="Uniform"
                                              Margin="0,0,8,0"/>
                                         <TextBox x:Name="BibleSearchBox"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  Foreground="{DynamicResource TextMain}"
                                                  MinHeight="26"
                                                  VerticalContentAlignment="Center"
                                                  KeyDown="BibleSearchBox_KeyDown"
                                                  ToolTip="Search by book, chapter, verse, or keyword"
                                                  Padding="4,0"/>
                                    </DockPanel>
                                </Border>
                                 <Button Content="Search"
                                         Click="BibleSearchButton_Click"
                                         Padding="18,10"
                                         Margin="0,0,8,0"
                                         Background="{DynamicResource AccentPrimary}"
                                         Foreground="{DynamicResource OnAccent}"
                                         BorderBrush="{DynamicResource AccentPrimary}"
                                         BorderThickness="1"
                                         Cursor="Hand"
                                         FontWeight="SemiBold"/>
                                 <Button Content="Clear"
                                          Click="BibleSearchClearButton_Click"
                                          Padding="16,10"
                                          Background="Transparent"
                                          Foreground="{DynamicResource TextMain}"
                                          BorderBrush="{DynamicResource BorderSoft}"
                                          BorderThickness="1"
                                          Cursor="Hand"/>

                                <Border Width="1" Margin="12,2,12,2" Background="{DynamicResource BorderSoft}"/>

                                 <Button Content="A-"
                                        Click="BibleFontSmallerButton_Click"
                                        Padding="10,8"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextMain}"
                                        BorderBrush="{DynamicResource BorderSoft}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        FontWeight="SemiBold"/>

                                <Slider x:Name="BibleFontSizeSlider"
                                        Width="72"
                                        Margin="8,0,8,0"
                                        Minimum="12"
                                        Maximum="28"
                                        Value="16"
                                        SmallChange="1"
                                        LargeChange="2"
                                        Style="{StaticResource LuxurySlider}"
                                        ValueChanged="BibleFontSizeSlider_ValueChanged"/>

                                 <Button Content="A+"
                                        Click="BibleFontLargerButton_Click"
                                        Padding="10,8"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextMain}"
                                        BorderBrush="{DynamicResource BorderSoft}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        FontWeight="SemiBold"/>
                            </StackPanel>

                             <WrapPanel Grid.Row="1"
                                        Margin="0,0,0,12">
                                <ComboBox x:Name="BookCombo"
                                          Width="160"
                                          Margin="0,0,10,0"
                                          SelectionChanged="BookCombo_SelectionChanged"
                                          Style="{StaticResource BibleBookComboBox}">
                                    <ComboBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
            <TextBlock Text="{Binding Name}"
                                                               Margin="8,12,8,6"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               FontFamily="{StaticResource FontUIBold}"
                                                               FontSize="12"/>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                            <GroupStyle.Panel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </GroupStyle.Panel>
                                        </GroupStyle>
                                    </ComboBox.GroupStyle>
                                </ComboBox>

                                <ComboBox x:Name="ChapterCombo"
                                           Width="120"
                                           Margin="0,0,10,0"
                                           SelectionChanged="ChapterCombo_SelectionChanged"
                                           Style="{StaticResource BibleNumberComboBox}"/>

                                <ComboBox x:Name="VerseStartCombo"
                                           Width="100"
                                           Margin="0,0,8,0"
                                           SelectionChanged="VerseStartCombo_SelectionChanged"
                                           Style="{StaticResource BibleNumberComboBox}"/>

                                <TextBlock Text="to"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource TextMuted}"/>

                                <ComboBox x:Name="VerseEndCombo"
                                          Width="100"
                                          Margin="0,0,10,0"
                                          SelectionChanged="VerseEndCombo_SelectionChanged"
                                          Style="{StaticResource BibleNumberComboBox}"/>

                                  <Button Content="Refresh"
                                           Click="RefreshBibleButton_Click"
                                           Padding="16,8"
                                           Background="{DynamicResource AccentPrimary}"
                                           Foreground="{DynamicResource OnAccent}"
                                           BorderBrush="{DynamicResource AccentPrimary}"
                                           BorderThickness="1"
                                           Cursor="Hand"
                                           FontWeight="SemiBold"/>

                             </WrapPanel>

                             <Grid Grid.Row="2">
                                 <Grid.RowDefinitions>
                                     <RowDefinition Height="Auto"/>
                                     <RowDefinition Height="*"/>
                                     <RowDefinition Height="Auto"/>
                                 </Grid.RowDefinitions>

                                 <!-- Offline download status -->
                                 <Border Grid.Row="0"
                                         x:Name="BibleDownloadPanel"
                                         Background="{DynamicResource BgCardSoft}"
                                         BorderBrush="{DynamicResource BorderSoft}"
                                         BorderThickness="1"
                                         CornerRadius="12"
                                         Padding="12"
                                         Margin="0,0,0,12"
                                         Visibility="Collapsed">
                                     <Grid>
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                         </Grid.ColumnDefinitions>
                                         <Grid.RowDefinitions>
                                             <RowDefinition Height="Auto"/>
                                             <RowDefinition Height="Auto"/>
                                         </Grid.RowDefinitions>

                                         <TextBlock x:Name="BibleDownloadStatus"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Text="Preparing offline Bible…"
                                                    Foreground="{DynamicResource TextMain}"
                                                    FontWeight="SemiBold"/>

                                         <Button x:Name="BibleDownloadCancelButton"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Content="Cancel"
                                                 Click="BibleDownloadCancelButton_Click"
                                                 Padding="12,6"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource TextMain}"
                                                 BorderBrush="{DynamicResource BorderSoft}"
                                                 BorderThickness="1"
                                                 Cursor="Hand"/>

                                         <ProgressBar x:Name="BibleDownloadProgress"
                                                      Grid.Row="1"
                                                      Grid.Column="0"
                                                      Grid.ColumnSpan="2"
                                                      Height="10"
                                                      Margin="0,10,0,0"
                                                      Minimum="0"
                                                      Maximum="100"/>
                                     </Grid>
                                 </Border>

                                  <Border Grid.Row="1"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="2"
                                          ClipToBounds="True">
                                      <Grid>
                                          <FlowDocumentScrollViewer x:Name="BibleReader"
                                                                    VerticalScrollBarVisibility="Auto"
                                                                    HorizontalScrollBarVisibility="Disabled"
                                                                    IsToolBarVisible="False"
                                                                    Background="Transparent"
                                                                    Foreground="{DynamicResource TextMain}"
                                                                    FontFamily="{StaticResource FontSubText}"
                                                                    FontSize="16"
                                                                    PreviewMouseWheel="BibleReader_PreviewMouseWheel"
                                                                    ClipToBounds="True"
                                                                    Visibility="Collapsed">
                                          </FlowDocumentScrollViewer>

                                          <Border x:Name="BibleComparePanel"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Visibility="Collapsed">
                                              <Grid>
                                                  <Grid.RowDefinitions>
                                                      <RowDefinition Height="Auto"/>
                                                      <RowDefinition Height="*"/>
                                                  </Grid.RowDefinitions>

                                                  <Grid Grid.Row="0" Margin="2,0,2,10">
                                                      <Grid.ColumnDefinitions>
                                                          <ColumnDefinition Width="60"/>
                                                          <ColumnDefinition Width="*"/>
                                                          <ColumnDefinition Width="*"/>
                                                      </Grid.ColumnDefinitions>

                                                      <TextBlock Grid.Column="1"
                                                                 x:Name="BibleCompareLeftHeader"
                                                                 Text=""
                                                                 Foreground="{DynamicResource TextMuted}"
                                                                 FontFamily="{StaticResource FontUIBold}"
                                                                 FontSize="12"/>
                                                      <TextBlock Grid.Column="2"
                                                                 x:Name="BibleCompareRightHeader"
                                                                 Text=""
                                                                 Foreground="{DynamicResource TextMuted}"
                                                                 FontFamily="{StaticResource FontUIBold}"
                                                                 FontSize="12"/>
                                                  </Grid>

                                                  <ListBox Grid.Row="1"
                                                           x:Name="BibleCompareList"
                                                           BorderThickness="0"
                                                           Background="Transparent"
                                                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                           ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                           FontFamily="{StaticResource FontSubText}"
                                                           FontSize="16">
                                                      <ListBox.ItemTemplate>
                                                          <DataTemplate>
                                                              <Border BorderBrush="{DynamicResource BorderSoft}"
                                                                      BorderThickness="0,0,0,1"
                                                                      Padding="0,10,0,10">
                                                                  <Grid>
                                                                      <Grid.ColumnDefinitions>
                                                                          <ColumnDefinition Width="60"/>
                                                                          <ColumnDefinition Width="*"/>
                                                                          <ColumnDefinition Width="*"/>
                                                                      </Grid.ColumnDefinitions>

                                                                      <TextBlock Grid.Column="0"
                                                                                 Text="{Binding VerseNumber}"
                                                                                 Foreground="{DynamicResource TextMuted}"
                                                                                 FontFamily="{StaticResource FontUIBold}"
                                                                                 VerticalAlignment="Top"
                                                                                 Margin="0,0,10,0"/>

                                                                      <TextBlock Grid.Column="1"
                                                                                 Text="{Binding LeftText}"
                                                                                 Foreground="{DynamicResource TextMain}"
                                                                                 TextWrapping="Wrap"
                                                                                 Margin="0,0,16,0"/>

                                                                      <TextBlock Grid.Column="2"
                                                                                 Text="{Binding RightText}"
                                                                                 Foreground="{DynamicResource TextMain}"
                                                                                 TextWrapping="Wrap"/>
                                                                  </Grid>
                                                              </Border>
                                                          </DataTemplate>
                                                      </ListBox.ItemTemplate>
                                                  </ListBox>
                                              </Grid>
                                          </Border>
                                      </Grid>
                                  </Border>

                                  <TextBlock Grid.Row="1"
                                             x:Name="BibleStatusText"
                                            Text="Select a book and chapter"
                                             Foreground="{DynamicResource TextMuted}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                              Background="{DynamicResource SelectionFill}"
                                               Padding="20"
                                              Visibility="Collapsed"/>

                                  <Border Grid.Row="2"
                                          Margin="0,16,0,0"
                                          Padding="0,12,0,0"
                                          BorderThickness="0,1,0,0"
                                          BorderBrush="{DynamicResource BorderSoft}"
                                          MaxHeight="260">
                                      <Grid>
                                          <Grid.RowDefinitions>
                                              <RowDefinition Height="Auto"/>
                                              <RowDefinition Height="Auto"/>
                                              <RowDefinition Height="*"/>
                                          </Grid.RowDefinitions>

                                          <TextBlock Grid.Row="0"
                                                     Text="Search results"
                                                     FontWeight="SemiBold"
                                                     Foreground="{DynamicResource TextMain}"/>
                                          <TextBlock Grid.Row="1"
                                                     x:Name="BibleSearchStatus"
                                                     Text="Enter a keyword to search across scripture."
                                                     Foreground="{DynamicResource TextMuted}"
                                                     Margin="0,4,0,8"/>

                                         <ListBox Grid.Row="2"
                                                  x:Name="BibleSearchResults"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  PreviewMouseLeftButtonUp="BibleSearchResults_PreviewMouseLeftButtonUp"
                                                  SelectionChanged="BibleSearchResults_SelectionChanged"
                                                  Visibility="Collapsed">
                                             <ListBox.ItemTemplate>
                                                 <DataTemplate>
                                                     <StackPanel Margin="0,0,0,12">
                                                          <TextBlock Text="{Binding Reference}"
                                                                     FontWeight="SemiBold"
                                                                     Foreground="{DynamicResource TextMain}"/>
                                                          <TextBlock Text="{Binding Text}"
                                                                     TextWrapping="Wrap"
                                                                     Foreground="{DynamicResource TextMuted}"/>
                                                      </StackPanel>
                                                  </DataTemplate>
                                              </ListBox.ItemTemplate>
                                          </ListBox>
                                      </Grid>
                                  </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>
        </Grid>
    </Grid>
</Window>
